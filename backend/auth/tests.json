{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "name": "Тест Тестов", "email": "test_montparnas_003@example.com", "password": "testpass123"},
      "expectedStatus": 200,
      "expectedBody": {"name": "Тест Тестов"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login user",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "test_montparnas_003@example.com", "password": "testpass123"},
      "expectedStatus": 200,
      "expectedBody": {"name": "Тест Тестов"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Wrong password",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "test_montparnas_003@example.com", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Неверный email или пароль"},
      "bodyMatcher": "partial"
    }
  ]
}
